generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "rhel-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// NextAuth models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id               String            @id @default(cuid())
  name             String?
  email            String            @unique
  password         String
  emailVerified    DateTime?
  image            String?
  role             String            @default("parent") // "parent" | "therapist"
  inviteCode       String?           @unique
  createdAt        DateTime          @default(now())
  accounts         Account[]
  sessions         Session[]
  children         ChildProfile[]
  therapistLinks   TherapistFamily[]    @relation("TherapistUser")
  parentLinks      TherapistFamily[]    @relation("ParentUser")
  customActivities Activity[]           @relation("CustomActivities")
  enrollments      ProspectEnrollment[] @relation("TherapistEnrollments")
  therapyPlans     TherapyPlan[]        @relation("TherapistPlans")
  therapistNotes   TherapistNote[]      @relation("TherapistNotes")
  hostedSessions   LiveSession[]        @relation("TherapistSessions")
  circleSchedules  CircleTimeSchedule[] @relation("TherapistSchedules")
}

model ChildProfile {
  id                  String              @id @default(cuid())
  name                String
  age                 Int
  avatarColor         String              @default("#FF6B6B")
  characteristics     String?             @db.Text // JSON: { communicationLevel, sensoryNeeds, interests, challenges, goals, notes }
  userId              String
  user                User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt           DateTime            @default(now())
  completedActivities CompletedActivity[]
  achievements        Achievement[]
  moodCheckIns        MoodCheckIn[]
  assignments         ActivityAssignment[]
  therapyPlans        TherapyPlan[]
  therapistNotes      TherapistNote[]
  emotionEvents       EmotionDetectionEvent[]
  confusionEvents     ConfusionEvent[]
  learningAdaptation  LearningAdaptation?
}

model Activity {
  id                  String               @id @default(cuid())
  title               String
  description         String
  type                String
  category            String?
  imageUrl            String?
  content             String               @db.Text
  difficulty          Int                  @default(1)
  starsReward         Int                  @default(1)
  createdBy           String?
  creator             User?                @relation("CustomActivities", fields: [createdBy], references: [id], onDelete: SetNull)
  createdAt           DateTime             @default(now())
  completedActivities CompletedActivity[]
  assignments         ActivityAssignment[]
  liveSessions        LiveSession[]        @relation("LiveSessions")
}

model CompletedActivity {
  id             String       @id @default(cuid())
  childId        String
  child          ChildProfile @relation(fields: [childId], references: [id], onDelete: Cascade)
  activityId     String
  activity       Activity     @relation(fields: [activityId], references: [id], onDelete: Cascade)
  completedAt    DateTime     @default(now())
  score          Int? // Optional score for the activity
  timeSpentSecs  Int? // Time spent in seconds

  @@unique([childId, activityId])
}

model Achievement {
  id          String       @id @default(cuid())
  childId     String
  child       ChildProfile @relation(fields: [childId], references: [id], onDelete: Cascade)
  title       String
  description String
  badgeType   String // "star", "trophy", "medal"
  badgeImage  String
  earnedAt    DateTime     @default(now())
}

model ProspectEnrollment {
  id          String          @id @default(cuid())
  therapistId String
  therapist   User            @relation("TherapistEnrollments", fields: [therapistId], references: [id], onDelete: Cascade)
  parentName  String
  parentEmail String
  token       String          @unique
  status      String          @default("pending") // "pending" | "completed"
  notes       String?         @db.Text
  goals       String?         @db.Text
  createdAt   DateTime        @default(now())
  completedAt DateTime?
  children    ProspectChild[]
}

model ProspectChild {
  id           String             @id @default(cuid())
  enrollmentId String
  enrollment   ProspectEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  name         String
  age          Int
  notes        String?
}

model TherapistFamily {
  id          String   @id @default(cuid())
  therapistId String
  therapist   User     @relation("TherapistUser", fields: [therapistId], references: [id], onDelete: Cascade)
  parentId    String
  parent      User     @relation("ParentUser", fields: [parentId], references: [id], onDelete: Cascade)
  linkedAt    DateTime @default(now())

  @@unique([therapistId, parentId])
}

model ActivityAssignment {
  id         String       @id @default(cuid())
  childId    String
  child      ChildProfile @relation(fields: [childId], references: [id], onDelete: Cascade)
  activityId String
  activity   Activity     @relation(fields: [activityId], references: [id], onDelete: Cascade)
  assignedBy String
  note       String?
  assignedAt DateTime     @default(now())

  @@unique([childId, activityId])
}

model MoodCheckIn {
  id        String       @id @default(cuid())
  childId   String
  child     ChildProfile @relation(fields: [childId], references: [id], onDelete: Cascade)
  mood      String       // "happy", "sad", "angry", "anxious", "calm", "excited", "tired"
  checkedAt DateTime     @default(now())
}

model TherapyPlan {
  id          String       @id @default(cuid())
  childId     String
  child       ChildProfile @relation(fields: [childId], references: [id], onDelete: Cascade)
  therapistId String
  therapist   User         @relation("TherapistPlans", fields: [therapistId], references: [id], onDelete: Cascade)
  title       String
  content     String       @db.Text // JSON: { durationWeeks, weeklyGoal, weeks: [{ weekNumber, focus, activities, tips }] }
  status      String       @default("active") // "active" | "completed" | "archived"
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model TherapistNote {
  id          String       @id @default(cuid())
  childId     String
  child       ChildProfile @relation(fields: [childId], references: [id], onDelete: Cascade)
  therapistId String
  therapist   User         @relation("TherapistNotes", fields: [therapistId], references: [id], onDelete: Cascade)
  content     String       @db.Text
  noteType    String       @default("observation") // "observation" | "recommendation" | "milestone"
  isShared    Boolean      @default(true)
  createdAt   DateTime     @default(now())
}

model EmotionDetectionEvent {
  id              String       @id @default(cuid())
  childId         String
  child           ChildProfile @relation(fields: [childId], references: [id], onDelete: Cascade)
  activityId      String?
  sessionId       String
  detectedEmotion String
  confidence      Float        @default(0.8)
  source          String
  timestamp       DateTime     @default(now())
}

model ConfusionEvent {
  id            String       @id @default(cuid())
  childId       String
  child         ChildProfile @relation(fields: [childId], references: [id], onDelete: Cascade)
  activityId    String
  activityType  String
  eventType     String
  hesitationMs  Int?
  attemptNumber Int          @default(1)
  questionCtx   String?
  timestamp     DateTime     @default(now())
}

model LearningAdaptation {
  id              String       @id @default(cuid())
  childId         String       @unique
  child           ChildProfile @relation(fields: [childId], references: [id], onDelete: Cascade)
  difficultyLevel Float        @default(0.5)
  preferredTypes  String       @default("[]")
  confusionAreas  String       @default("{}")
  totalHints      Int          @default(0)
  lastUpdated     DateTime     @updatedAt
}

model LiveSession {
  id           String           @id @default(cuid())
  joinCode     String           @unique
  activityId   String
  activity     Activity         @relation("LiveSessions", fields: [activityId], references: [id], onDelete: Cascade)
  therapistId  String?
  therapist    User?            @relation("TherapistSessions", fields: [therapistId], references: [id], onDelete: SetNull)
  status       String           @default("waiting")
  currentPage  Int              @default(0)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  participants LiveParticipant[]
}

model CircleTimeSchedule {
  id          String   @id @default(cuid())
  therapistId String
  therapist   User     @relation("TherapistSchedules", fields: [therapistId], references: [id], onDelete: Cascade)
  dayOfWeek   Int      // 0=Sun 1=Mon 2=Tue 3=Wed 4=Thu 5=Fri 6=Sat
  timeOfDay   String   // "14:30" HH:mm
  title       String
  activityId  String?
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model LiveParticipant {
  id             String      @id @default(cuid())
  sessionId      String
  session        LiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  displayName    String
  childId        String?
  avatarColor    String      @default("#818CF8")
  isHost         Boolean     @default(false)
  currentEmotion String      @default("neutral")
  joinedAt       DateTime    @default(now())
  lastSeen       DateTime    @default(now())

  @@index([sessionId])
}
