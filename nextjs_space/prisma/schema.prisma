generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "rhel-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// NextAuth models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id               String            @id @default(cuid())
  name             String?
  email            String            @unique
  password         String
  emailVerified    DateTime?
  image            String?
  role             String            @default("parent") // "parent" | "therapist"
  inviteCode       String?           @unique
  createdAt        DateTime          @default(now())
  accounts         Account[]
  sessions         Session[]
  children         ChildProfile[]
  therapistLinks   TherapistFamily[] @relation("TherapistUser")
  parentLinks      TherapistFamily[] @relation("ParentUser")
  customActivities Activity[]        @relation("CustomActivities")
}

model ChildProfile {
  id                  String              @id @default(cuid())
  name                String
  age                 Int
  avatarColor         String              @default("#FF6B6B")
  userId              String
  user                User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt           DateTime            @default(now())
  completedActivities CompletedActivity[]
  achievements        Achievement[]
  moodCheckIns        MoodCheckIn[]
  assignments         ActivityAssignment[]
}

model Activity {
  id                  String               @id @default(cuid())
  title               String
  description         String
  type                String
  category            String?
  imageUrl            String?
  content             String               @db.Text
  difficulty          Int                  @default(1)
  starsReward         Int                  @default(1)
  createdBy           String?
  creator             User?                @relation("CustomActivities", fields: [createdBy], references: [id], onDelete: SetNull)
  createdAt           DateTime             @default(now())
  completedActivities CompletedActivity[]
  assignments         ActivityAssignment[]
}

model CompletedActivity {
  id             String       @id @default(cuid())
  childId        String
  child          ChildProfile @relation(fields: [childId], references: [id], onDelete: Cascade)
  activityId     String
  activity       Activity     @relation(fields: [activityId], references: [id], onDelete: Cascade)
  completedAt    DateTime     @default(now())
  score          Int? // Optional score for the activity
  timeSpentSecs  Int? // Time spent in seconds

  @@unique([childId, activityId])
}

model Achievement {
  id          String       @id @default(cuid())
  childId     String
  child       ChildProfile @relation(fields: [childId], references: [id], onDelete: Cascade)
  title       String
  description String
  badgeType   String // "star", "trophy", "medal"
  badgeImage  String
  earnedAt    DateTime     @default(now())
}

model TherapistFamily {
  id          String   @id @default(cuid())
  therapistId String
  therapist   User     @relation("TherapistUser", fields: [therapistId], references: [id], onDelete: Cascade)
  parentId    String
  parent      User     @relation("ParentUser", fields: [parentId], references: [id], onDelete: Cascade)
  linkedAt    DateTime @default(now())

  @@unique([therapistId, parentId])
}

model ActivityAssignment {
  id         String       @id @default(cuid())
  childId    String
  child      ChildProfile @relation(fields: [childId], references: [id], onDelete: Cascade)
  activityId String
  activity   Activity     @relation(fields: [activityId], references: [id], onDelete: Cascade)
  assignedBy String
  note       String?
  assignedAt DateTime     @default(now())

  @@unique([childId, activityId])
}

model MoodCheckIn {
  id        String       @id @default(cuid())
  childId   String
  child     ChildProfile @relation(fields: [childId], references: [id], onDelete: Cascade)
  mood      String       // "happy", "sad", "angry", "anxious", "calm", "excited", "tired"
  checkedAt DateTime     @default(now())
}
